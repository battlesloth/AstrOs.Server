{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "es2022",
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "noEmit": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "paths": {
      "@api/*": ["../astros_api/src/*"],
      "src/*": ["../astros_api/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../astros_api/src/**/*.ts"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "../astros_api/src/**/*.test.ts",
    "../astros_api/src/**/*.spec.ts",
    "../astros_api/src/background_tasks/**",
    "src/web/ui/**"
  ]
}
