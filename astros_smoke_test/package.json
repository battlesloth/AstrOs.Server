{
  "name": "astros-smoke-test",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Smoke test harness for AstrOs ESP32 master/padawan hardware",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "eslint . --ext .js,.jsx,.ts,.tsx && tsc --noEmit",
    "test": "vitest",
    "smoke": "tsx ./src/cli/index.ts",
    "smoke:list": "tsx ./src/cli/index.ts list",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "prettier:check": "prettier --check \"src/**/*.ts\"",
    "prettier:write": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@types/node": "22.13.10",
    "@types/serialport": "^8.0.5",
    "appdata-path": "^1.0.0",
    "pino": "^8.8.0",
    "pino-roll": "^4.0.0",
    "serialport": "^12.0.0",
    "tslib": "^2.4.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.8.0",
    "@typescript-eslint/parser": "^5.8.0",
    "eslint": "^8.5.0",
    "eslint-plugin-require-extensions": "^0.1.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.3",
    "typescript": "~5.1.6",
    "vitest": "^3.0.8"
  }
}
