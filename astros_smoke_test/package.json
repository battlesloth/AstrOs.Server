{
  "name": "astros-smoke-test",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Smoke test harness for AstrOs ESP32 master/padawan hardware",
  "scripts": {
    "typecheck:server": "tsc --noEmit",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:server && npm run typecheck:web",
    "build": "eslint . --ext .js,.jsx,.ts,.tsx,.vue && npm run typecheck",
    "test": "vitest",
    "smoke": "tsx ./src/cli/index.ts",
    "smoke:list": "tsx ./src/cli/index.ts list",
    "web:dev": "tsx ./src/web/server.ts",
    "web:build": "vite build --config vite.web.config.ts",
    "web": "NODE_ENV=production tsx ./src/web/server.ts",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.vue --fix",
    "prettier:check": "prettier --check \"src/**/*.ts\"",
    "prettier:write": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@types/node": "22.13.10",
    "@types/serialport": "^8.0.5",
    "appdata-path": "^1.0.0",
    "express": "4.21.2",
    "pino": "^8.8.0",
    "serialport": "^12.0.0",
    "tslib": "^2.4.1",
    "uuid": "^11.1.0",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@typescript-eslint/eslint-plugin": "^5.8.0",
    "@typescript-eslint/parser": "^5.8.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "eslint": "^8.5.0",
    "eslint-plugin-require-extensions": "^0.1.3",
    "eslint-plugin-vue": "^9.32.0",
    "pino-pretty": "^11.0.0",
    "vue-eslint-parser": "^9.4.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.3",
    "typescript": "~5.1.6",
    "vite": "^7.2.4",
    "vitest": "^3.0.8",
    "vue-tsc": "^1.8.27"
  }
}
