{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "nodejs",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/astros_api",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "start"
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "build server"
    },
    {
      "name": "vue",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/astros_vue",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "dev"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "angular",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/astros_client",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "start"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "angular_browser",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/astros_client",
      "userDataDir": "${workspaceRoot}/.vscode/edge"
    },
    {
      "name": "smoke (cli)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/astros_smoke_test",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "smoke",
        "--",
        "${input:smokeScenario}"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "smoke web",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/astros_smoke_test",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "web:dev"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "smoke browser",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5174",
      "webRoot": "${workspaceFolder}/astros_smoke_test/src/web/ui",
      "userDataDir": "${workspaceRoot}/.vscode/edge-smoke"
    }
  ],
  "compounds": [
    {
      "name": "server/client",
      "configurations": [
        "nodejs",
        "angular",
        "angular_browser"
      ]
    },
    {
      "name": "server/vue",
      "configurations": [
        "nodejs",
        "vue"
      ]
    },
    {
      "name": "smoke web + browser",
      "configurations": [
        "smoke web",
        "smoke browser"
      ]
    }
  ],
  "inputs": [
    {
      "id": "smokeScenario",
      "type": "pickString",
      "description": "Smoke test scenario (destructive ones need --confirm via terminal)",
      "default": "list",
      "options": [
        "list",
        "sync-only",
        "format-and-sync",
        "config-only",
        "full-happy-path",
        "direct-command-sweep",
        "servo-test-sweep",
        "panic-drill"
      ]
    }
  ]
}
